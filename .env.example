# Firebase Configuration Environment Variables
# Copy this file to .env and fill in your values

# Project ID from Firebase Console
FIREBASE_PROJECT_ID=task-manager-c98ec

# Service Account Credentials (from Firebase Console → Project Settings → Service Accounts)
# Download the JSON file and extract these values:
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@task-manager-c98ec.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your_client_id
FIREBASE_CLIENT_CERT_URL=https://firebase-storage.googleapis.com/v1/projects/task-manager-c98ec/serviceAccounts

# Optional: Server Port
# PORT=3000